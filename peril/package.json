{
  "dependencies": {
    "jest": "^24.9.0"
  },
  "scripts": {
    "test": "jest"
  },
  "jest": {
    "rootDir": "../",
    "roots": [
      "<rootDir>/peril"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "diagnostics": false,
          "isolatedModules": true,
          "tsconfig": "<rootDir>/peril/tsconfig.json"
        }
      ]
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ]
  }
}
